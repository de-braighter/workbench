{
  "mcpServers": {
    "devloop-knowledge-graph": {
      "command": "node",
      "args": [
        "domains/devloop/node_modules/tsx/dist/cli.mjs",
        "domains/devloop/src/knowledge-graph/mcp/server.ts"
      ],
      "env": {
        "DEVLOOP_MEMORY_DIR": "${HOME}/.claude/projects/D--development-projects-de-braighter/memory",
        "KG_S3_ENDPOINT": "https://s3.swiss-backup04.infomaniak.com",
        "KG_S3_BUCKET": "de-braighter-kg-index-prod",
        "KG_S3_KEY": "kg-index.json",
        "KG_S3_REGION": "us-east-1",
        "KG_S3_ACCESS_KEY_ID": "${KG_S3_ACCESS_KEY_ID}",
        "KG_S3_SECRET_ACCESS_KEY": "${KG_S3_SECRET_ACCESS_KEY}"
      }
    },
    "foundry": {
      "command": "node",
      "args": [
        "domains/foundry/node_modules/tsx/dist/cli.mjs",
        "domains/foundry/src/mcp/server.ts"
      ]
    },
    "knowledge": {
      "command": "node",
      "args": [
        "layers/knowledge/node_modules/tsx/dist/cli.mjs",
        "layers/knowledge/src/mcp/server.ts"
      ],
      "env": {
        "KNOWLEDGE_MEMORY_STORE": "postgres",
        "KNOWLEDGE_DATABASE_URL": "${KNOWLEDGE_DATABASE_URL}",
        "KNOWLEDGE_TENANT_PACK_ID": "${KNOWLEDGE_TENANT_PACK_ID}"
      }
    }
  }
}
