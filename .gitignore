# Layer sibling repos (each has its own .git)
layers/*
!layers/.gitkeep

# Domain sibling repos (each has its own .git)
domains/*
!domains/.gitkeep

# Attic is a sibling git repo (preservation only)
attic/

# Build / runtime artifacts
node_modules/
dist/
.nx/
.angular/
tmp/
*.log
# Generated test-coverage output (leaks into the root when a coverage run is invoked here)
coverage/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Local-only settings (Claude Code)
.claude/settings.local.json
_attic/

# Ideas inbox — raw founder inputs are scratch; only the README contract is tracked
docs/ideas-inbox/*
!docs/ideas-inbox/README.md

# Local-only secrets — never commit
.env
.env.*
!.env.example
